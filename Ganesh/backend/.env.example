# InsightForge AI — Environment template
# cp .env.example .env

APP_NAME=InsightForge AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=insightforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=insightforge_db
# DATABASE_URL=postgresql+asyncpg://insightforge:CHANGE_ME@localhost:5432/insightforge_db

FRONTEND_URL=http://localhost:5173

JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

PASSWORD_RESET_EXPIRE_HOURS=24
EMAIL_VERIFICATION_EXPIRE_HOURS=72

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
